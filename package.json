{
  "name": "khmer-chhankitek-calendar",
  "version": "0.1.11",
  "description": "Khmer lunar calendar utilities for JavaScript and TypeScript with Khmer date conversion, formatting, holy days, and holiday support.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "khmer",
    "calendar",
    "chhankitek",
    "chankitek",
    "khmer-calendar",
    "khmer-lunar-calendar",
    "khmer-chhankitek-calendar",
    "lunar",
    "lunar-calendar",
    "cambodia",
    "cambodian-calendar",
    "khmer-date",
    "khmer-lunar-date",
    "khmer-holiday",
    "buddhist-calendar",
    "khmer-buddhist-era",
    "holiday",
    "typescript",
    "javascript",
    "nodejs",
    "browser",
    "react",
    "angular",
    "vue",
    "nextjs",
    "nuxt",
    "svelte",
    "express",
    "date",
    "typescript-library"
  ],
  "author": "Choch Kimhour <Cambodia>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://www.npmjs.com/package/khmer-chhankitek-calendar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chochkimhour/khmer-chhankitek-calendar.git"
  },
  "bugs": {
    "url": "https://github.com/chochkimhour/khmer-chhankitek-calendar/issues"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.0.0"
  }
}
